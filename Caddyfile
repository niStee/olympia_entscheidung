# =============================================================================
# Caddyfile – Reverse proxy configuration for Wahl-Check
#
# Variables are injected from the container environment by Docker Compose:
#   CADDY_DOMAIN      – public domain name for the quiz app
#   CADDY_INFO_DOMAIN – public domain name for the info app
#   CADDY_EMAIL       – email for ACME / Let's Encrypt certificate registration
#
# Caddy automatically:
#   - obtains and renews TLS certificates via Let's Encrypt
#   - redirects HTTP (port 80) to HTTPS (port 443)
# =============================================================================

{
  email {$CADDY_EMAIL}
  # Uncomment to use Let's Encrypt staging (for testing, avoids rate limits):
  # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$CADDY_DOMAIN} {
  # Proxy all traffic to the Next.js app container (internal Docker network)
  # The app listens on port 8081 inside its container.
  reverse_proxy app:8081

  # Compress responses
  encode gzip

  # Security headers
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; img-src 'self' data: blob: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; manifest-src 'self'; worker-src 'self' blob:; upgrade-insecure-requests"
    -Server
  }

  @analytics path /api/analytics
  header @analytics Cache-Control "no-store, max-age=0"

  @pwaMutable {
    path /manifest.json /sw.js
  }
  header @pwaMutable Cache-Control "public, max-age=0, must-revalidate"

  # Long-term cache for immutable static assets
  @static {
    path /_next/static/* /icons/*
  }
  header @static Cache-Control "public, max-age=31536000, immutable"
}

{$CADDY_INFO_DOMAIN} {
  reverse_proxy info:80

  encode gzip

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; img-src 'self' data: blob: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; upgrade-insecure-requests"
    -Server
  }

  @static {
    path /assets/*
  }
  header @static Cache-Control "public, max-age=31536000, immutable"
}
