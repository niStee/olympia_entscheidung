{
  "name": "olympia-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo für Olympia Düsseldorf Projekte",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/**\" dev",
    "dev:info": "pnpm --filter info dev",
    "dev:olympia": "pnpm --filter olympia dev",
    "build": "pnpm --filter \"./apps/**\" build",
    "build:info": "pnpm --filter info build",
    "build:olympia": "pnpm --filter olympia build",
    "lint": "pnpm --filter \"./apps/**\" lint",
    "type-check": "pnpm --filter \"./apps/**\" type-check",
    "test": "pnpm --filter \"./apps/**\" test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm --filter \"./apps/**\" clean"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
